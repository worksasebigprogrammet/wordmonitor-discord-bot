# ─────────────────────────────────────────────────────────
# WorldMonitor — Configuration (.env)
# Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────

# ── OBLIGATOIRE ──────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/worldmonitor

# ── TRADUCTION (Fortement recommendé) ───────────────────
# Clé DeepL Free: https://www.deepl.com/pro#developer
# Les clés gratuites se terminent par :fx
DEEPL_API_KEY=your_deepl_api_key:fx

# ── APIS OPTIONNELLES (100% facultatif) ─────────────────
# NewsAPI: https://newsapi.org/ (100 req/jour gratuit)
NEWSAPI_KEY=

# Mediastack: https://mediastack.com/ (500 req/mois gratuit)
MEDIASTACK_API=

# CurrentsAPI: https://currentsapi.services/ (600 req/jour gratuit)
CURRENTS_API=

# ── BOT CONFIGURATION ────────────────────────────────────
# Intervalle de scraping en ms (défaut: 300000 = 5 min)
SCRAPE_INTERVAL=300000

# Intervalle mise à jour index en ms (défaut: 600000 = 10 min)
INDEX_UPDATE_INTERVAL=600000

# Durée de vie des news en heures (défaut: 24)
NEWS_TTL_HOURS=24

# Max articles traités par cycle (défaut: 50)
MAX_NEWS_PER_CYCLE=50

# Délai entre les sources en ms (défaut: 2000 = 2s)
SOURCE_DELAY=2000

# ── LOGGING ──────────────────────────────────────────────
# Niveaux: error, warn, info, debug
LOG_LEVEL=info

# ── ENVIRONMENT ──────────────────────────────────────────
NODE_ENV=production
